# ============================================================
# App
# ============================================================
APP_ENV=development
APP_NAME=DSEC AI Case Review System
APP_VERSION=1.0.0
DEBUG=true
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
FRONTEND_URL=http://localhost:3000

# ============================================================
# Database
# ============================================================
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/dsec
DATABASE_ECHO=false

# ============================================================
# JWT
# ============================================================
JWT_SECRET=change-me-jwt-secret-32-chars-minimum
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ============================================================
# OpenAI
# ============================================================
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o
OPENAI_EMBEDDING_DIMENSION=1536

# ============================================================
# S3 / MinIO
# ============================================================
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=dsec-attachments
S3_REGION=us-east-1
S3_PRESIGN_EXPIRE_SECONDS=900

# ============================================================
# Email (SMTP)
# ============================================================
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@dsec.dji.com
SMTP_TLS=false

# ============================================================
# RAG
# ============================================================
RAG_TOP_K_RUBRIC=5
RAG_TOP_K_CASES=5
RAG_TOP_K_REVIEWS=3
RAG_TOP_K_DISAGREEMENTS=2
RAG_CONFIDENCE_THRESHOLD=0.6
DISAGREEMENT_MAJOR_THRESHOLD=20.0
DISAGREEMENT_CRITICAL_THRESHOLD=25.0

# ============================================================
# SLA (hours)
# ============================================================
SLA_PLATFORM_REVIEW_HOURS=48
SLA_DJI_REVIEW_HOURS=72
CASE_WITHDRAW_WINDOW_MINUTES=5
